# Supabase — create a project at https://supabase.com and copy these from
# Project Settings → API. Then save real values in .env.local (untracked).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: used by Route Handlers for privileged operations (place_order).
# Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=
