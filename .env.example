# Supabase — create a project at https://supabase.com and copy these from
# Project Settings → API. Then save real values in .env.local (untracked).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: used by Route Handlers for privileged operations (place_order).
# Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Google Maps (optional) — enables the REAL live-tracking map (real Fès tiles +
# driving route). Create a key in Google Cloud Console with the "Maps
# JavaScript API", "Directions API" and "Geocoding API" enabled, then restrict
# it to your domain. If left blank, tracking falls back to the built-in SVG map.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
